<UserControl x:Class="KargoRaf.Controls.SearchBoxControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             FontFamily="{StaticResource AppFont}">

    <Border x:Name="Shell"
            Background="{Binding ShellBackground, RelativeSource={RelativeSource AncestorType=UserControl}}"
            BorderBrush="{Binding ShellBorderBrush, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue={StaticResource BorderBrush}, TargetNullValue={StaticResource BorderBrush}}"
            CornerRadius="10" BorderThickness="1" Padding="2,1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Path Grid.Column="0" Data="{StaticResource IconSearch}" Style="{StaticResource IconPath}"
                  Width="14" Height="14" Stroke="{StaticResource MutedTextBrush}" Margin="8,0,4,0"/>

            <TextBox x:Name="SearchInput"
                     Grid.Column="1"
                     Style="{StaticResource ModernTextBox}"
                     BorderThickness="0"
                     MinHeight="28"
                     FontSize="12"
                     Padding="2,4"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

            <Button Grid.Column="2"
                    Style="{StaticResource ToolbarIconButton}"
                    Width="26" Height="26"
                    ToolTip="Temizle"
                    Command="{Binding ClearSearchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    Visibility="{Binding SearchText, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource NullOrEmptyToVis}}">
                <Path Data="{StaticResource IconClose}" Style="{StaticResource IconPath}"
                      Width="14" Height="14" Stroke="{StaticResource MutedTextBrush}"/>
            </Button>
        </Grid>
    </Border>
</UserControl>
