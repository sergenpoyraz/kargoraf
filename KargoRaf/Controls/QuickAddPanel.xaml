<UserControl x:Class="KargoRaf.Controls.QuickAddPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource AppFont}">

    <Border Style="{StaticResource HeroPanel}" Padding="14,12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="QuickAddBox"
                         Style="{StaticResource HeroTextBox}"
                         MinHeight="48"
                         FontSize="20"
                         Padding="14,10"
                         Text="{Binding QuickAddName, UpdateSourceTrigger=PropertyChanged}"
                         PreviewKeyDown="QuickAddBox_PreviewKeyDown"/>
                <TextBlock Text="Alıcı adı yazın…"
                           IsHitTestVisible="False"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="20" FontWeight="SemiBold"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"
                           Visibility="{Binding QuickAddName, Converter={StaticResource NullOrEmptyToVis}, ConverterParameter=Invert}"/>
                <Border Grid.Column="1" Background="{StaticResource PrimaryBrush}"
                        CornerRadius="8" Padding="10,6" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SelectedSectionDisplay}"
                               Foreground="White" FontSize="11" FontWeight="Bold"/>
                </Border>
            </Grid>

            <TextBox Grid.Row="1"
                     Style="{StaticResource ModernTextBox}"
                     Margin="0,0,0,8"
                     MinHeight="36"
                     FontSize="13"
                     MaxLength="500"
                     BorderBrush="{StaticResource NoteBorderBrush}"
                     Background="{StaticResource NoteSurfaceBrush}"
                     Text="{Binding QuickAddNotes, UpdateSourceTrigger=PropertyChanged}"
                     Visibility="{Binding ShowQuickAddNotes, Converter={StaticResource BoolToVis}}"/>

            <Grid Grid.Row="2" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource NoteToggleChip}"
                            Command="{Binding ToggleQuickAddNotesCommand}"
                            Margin="0,0,8,0"
                            Visibility="{Binding ShowQuickAddNotes, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconNote}" Style="{StaticResource IconPath}"
                                  Width="13" Height="13" Stroke="{StaticResource WarningBrush}" Margin="0,0,5,0"/>
                            <TextBlock Text="Not" FontSize="11"/>
                        </StackPanel>
                    </Button>

                    <ItemsControl ItemsSource="{Binding SectionButtons}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ToggleButton Content="{Binding}"
                                              Style="{StaticResource SectionSelectButton}"
                                              Width="44" Height="44" FontSize="17"
                                              Margin="0,0,6,0"
                                              Click="SectionButton_Click"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <Button Grid.Column="1"
                        Style="{StaticResource HeroAddButton}"
                        Content="Ekle"
                        MinWidth="96"
                        MinHeight="44"
                        FontSize="15"
                        Padding="20,0"
                        Command="{Binding AddCommand}"/>
            </Grid>

            <TextBlock Grid.Row="3"
                       Text="{Binding WarningMessage}"
                       Foreground="{StaticResource WarningBrush}"
                       FontSize="12" FontWeight="SemiBold"
                       Visibility="{Binding WarningMessage, Converter={StaticResource NullOrEmptyToVis}, ConverterParameter=Invert}"/>
        </Grid>
    </Border>
</UserControl>
