<UserControl x:Class="KargoRaf.Controls.QuickAddPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource AppFont}"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             VerticalAlignment="Top">

    <Border Background="{StaticResource HeroTintBrush}"
            BorderBrush="#FDBA74"
            BorderThickness="1"
            CornerRadius="16"
            Padding="10,8,10,2"
            VerticalAlignment="Top">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Satir 1: isim + not + ekle -->
            <Grid Grid.Row="0" Height="46">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <TextBox x:Name="QuickAddBox"
                             Style="{StaticResource QuickAddTextBox}"
                             Text="{Binding QuickAddName, UpdateSourceTrigger=PropertyChanged}"
                             PreviewKeyDown="QuickAddBox_PreviewKeyDown"/>
                    <TextBlock Text="Alıcı adı yazın…"
                               IsHitTestVisible="False"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="18" FontWeight="SemiBold"
                               Margin="14,0,0,0"
                               VerticalAlignment="Center"
                               Visibility="{Binding QuickAddName, Converter={StaticResource NullOrEmptyToVis}, ConverterParameter=Invert}"/>
                </Grid>

                <Button Grid.Column="1"
                        Style="{StaticResource QuickAddNoteChip}"
                        Command="{Binding ToggleQuickAddNotesCommand}"
                        Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconNote}" Style="{StaticResource IconPath}"
                              Width="13" Height="13" Stroke="{StaticResource WarningBrush}" Margin="0,0,5,0"/>
                        <TextBlock FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Not"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowQuickAddNotes}" Value="True">
                                            <Setter Property="Text" Value="Gizle"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button>

                <Button Grid.Column="2"
                        Style="{StaticResource QuickAddAddButton}"
                        Content="Ekle"
                        Margin="8,0,0,0"
                        Command="{Binding AddCommand}"/>
            </Grid>

            <!-- Satir 2: not (acikken) -->
            <TextBox Grid.Row="1"
                     Margin="0,8,0,0"
                     Style="{StaticResource ModernTextBox}"
                     MinHeight="34"
                     FontSize="12"
                     MaxLength="500"
                     BorderBrush="{StaticResource NoteBorderBrush}"
                     Background="{StaticResource NoteSurfaceBrush}"
                     Text="{Binding QuickAddNotes, UpdateSourceTrigger=PropertyChanged}"
                     Visibility="{Binding ShowQuickAddNotes, Converter={StaticResource BoolToVis}}"/>

            <!-- Satir 3: bolum butonlari -->
            <ItemsControl Grid.Row="2"
                          Margin="0,6,0,0"
                          ItemsSource="{Binding Sections}"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ToggleButton Style="{StaticResource SectionSelectButton}"
                                      Tag="{Binding SortOrder}"
                                      Click="SectionButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="28" Height="28" CornerRadius="8" Margin="0,0,10,0"
                                        Background="{Binding AccentBrush}">
                                    <TextBlock Text="{Binding SortOrder}"
                                               Foreground="White" FontSize="16" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding Name}"
                                           FontSize="15" FontWeight="Bold"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="160"/>
                            </StackPanel>
                        </ToggleButton>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Satir 4: uyari - boşken kesinlikle yer kaplamaz -->
            <TextBlock Grid.Row="3"
                       Text="{Binding WarningMessage, TargetNullValue=''}"
                       Foreground="{StaticResource WarningBrush}"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Margin="0,6,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="Text" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
    </Border>
</UserControl>
