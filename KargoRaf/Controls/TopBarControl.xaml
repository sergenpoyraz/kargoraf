<UserControl x:Class="KargoRaf.Controls.TopBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:KargoRaf.Controls"
             FontFamily="{StaticResource AppFont}">

    <Border Style="{StaticResource TopBarShell}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                <Border Width="44" Height="44"
                        CornerRadius="16"
                        Background="{StaticResource PrimaryBrush}"
                        Margin="0,0,12,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.16" Color="#2563EB"/>
                    </Border.Effect>
                    <Path Data="{StaticResource LogoMark}"
                          Width="28" Height="28"
                          Stretch="Uniform"
                          Fill="White"
                          Opacity="0.98"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Kargo Raf" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="Bölümlere göre kargo takibi"
                               FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <controls:SearchBoxControl x:Name="SearchBox"
                                       Grid.Column="1"
                                       MaxWidth="320"
                                       HorizontalAlignment="Stretch"
                                       Margin="0,0,16,0"
                                       SearchText="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                       ClearSearchCommand="{Binding ClearSearchCommand}"/>

            <Border Grid.Column="2" Width="1" Background="{StaticResource BorderBrush}" Margin="0,4,16,4"/>

            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource ToolbarButton}" Command="{Binding OpenHistoryCommand}" Margin="0,0,6,0" Padding="12,8">
                    <StackPanel HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconHistory}" Style="{StaticResource IconPath}" Width="18" Height="18" Stroke="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="Geçmiş" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ToolbarButton}" Command="{Binding ToggleWidgetCommand}" ToolTip="Ctrl+W" Margin="0,0,6,0" Padding="12,8">
                    <StackPanel HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconWidget}" Style="{StaticResource IconPath}" Width="18" Height="18" Stroke="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="Widget" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ToolbarButton}" Command="{Binding BackupCommand}" Margin="0,0,6,0" Padding="12,8">
                    <StackPanel HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconBackup}" Style="{StaticResource IconPath}" Width="18" Height="18" Stroke="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="Yedek" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ToolbarButton}" Command="{Binding OpenSettingsCommand}" Padding="12,8">
                    <StackPanel HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconSettings}" Style="{StaticResource IconPath}" Width="18" Height="18" Stroke="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="Ayarlar" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
