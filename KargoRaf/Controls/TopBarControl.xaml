<UserControl x:Class="KargoRaf.Controls.TopBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:KargoRaf.Controls"
             FontFamily="{StaticResource AppFont}">

    <Border Style="{StaticResource TopBarShell}" Padding="12,8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                <Image Source="pack://application:,,,/Assets/AppIcon.png"
                       Style="{StaticResource LogoImage}"
                       Margin="0,0,10,0"/>
                <TextBlock Text="Kargo Raf" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <controls:SearchBoxControl x:Name="SearchBox"
                                       Grid.Column="1"
                                       MaxWidth="300"
                                       HorizontalAlignment="Stretch"
                                       Margin="0,0,12,0"
                                       SearchText="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                       ClearSearchCommand="{Binding ClearSearchCommand}"/>

            <Border Grid.Column="2" Width="1" Background="{StaticResource BorderBrush}" Margin="0,2,12,2"/>

            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource IconButton}" Command="{Binding OpenHistoryCommand}" ToolTip="Geçmiş" Margin="0,0,4,0">
                    <Path Data="{StaticResource IconHistory}" Style="{StaticResource IconPath}" Width="18" Height="18" Stroke="{StaticResource PrimaryBrush}"/>
                </Button>
                <Button Style="{StaticResource IconButton}" Command="{Binding ToggleWidgetCommand}" ToolTip="Widget (Ctrl+W)" Margin="0,0,4,0">
                    <Path Data="{StaticResource IconWidget}" Style="{StaticResource IconPath}" Width="18" Height="18" Stroke="{StaticResource PrimaryBrush}"/>
                </Button>
                <Button Style="{StaticResource IconButton}" Command="{Binding BackupCommand}" ToolTip="Yedek" Margin="0,0,4,0">
                    <Path Data="{StaticResource IconBackup}" Style="{StaticResource IconPath}" Width="18" Height="18" Stroke="{StaticResource PrimaryBrush}"/>
                </Button>
                <Button Style="{StaticResource IconButton}" Command="{Binding OpenSettingsCommand}" ToolTip="Ayarlar">
                    <Path Data="{StaticResource IconSettings}" Style="{StaticResource IconPath}" Width="18" Height="18" Stroke="{StaticResource PrimaryBrush}"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
