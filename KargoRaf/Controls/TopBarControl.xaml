<UserControl x:Class="KargoRaf.Controls.TopBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:KargoRaf.Controls"
             FontFamily="{StaticResource AppFont}">

    <StackPanel>
        <Border Style="{StaticResource CompactToolbarShell}" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0"
                       Source="pack://application:,,,/Assets/AppIcon.png"
                       Width="24" Height="24"
                       Stretch="Uniform"
                       Margin="0,0,8,0"
                       VerticalAlignment="Center">
                    <Image.ToolTip>
                        <ToolTip Content="Kargo Raf"/>
                    </Image.ToolTip>
                </Image>

                <controls:SearchBoxControl x:Name="SearchBox"
                                           Grid.Column="1"
                                           HorizontalAlignment="Stretch"
                                           Margin="0,0,10,0"
                                           SearchText="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                           ClearSearchCommand="{Binding ClearSearchCommand}"/>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0">
                    <TextBlock FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,10,0">
                        <Run Text="Aktif"/>
                        <Run Text="{Binding TotalActiveCount}" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                    </TextBlock>
                    <TextBlock FontSize="11" Foreground="{StaticResource MutedTextBrush}">
                        <Run Text="Bugün"/>
                        <Run Text="{Binding TodayAddedCount}" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="3"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolbarIconButton}"
                            Command="{Binding OpenHistoryCommand}"
                            ToolTip="Geçmiş"
                            Margin="0,0,2,0">
                        <Path Data="{StaticResource IconHistory}" Style="{StaticResource IconPath}" Width="16" Height="16" Stroke="{StaticResource PrimaryBrush}"/>
                    </Button>
                    <Button Style="{StaticResource ToolbarIconButton}"
                            Command="{Binding ToggleWidgetCommand}"
                            ToolTip="Widget (Ctrl+W)"
                            Margin="0,0,2,0">
                        <Path Data="{StaticResource IconWidget}" Style="{StaticResource IconPath}" Width="16" Height="16" Stroke="{StaticResource PrimaryBrush}"/>
                    </Button>
                    <Button Style="{StaticResource ToolbarIconButton}"
                            Command="{Binding BackupCommand}"
                            ToolTip="Yedek"
                            Margin="0,0,2,0">
                        <Path Data="{StaticResource IconBackup}" Style="{StaticResource IconPath}" Width="16" Height="16" Stroke="{StaticResource PrimaryBrush}"/>
                    </Button>
                    <Button Style="{StaticResource ToolbarIconButton}"
                            Command="{Binding OpenSettingsCommand}"
                            ToolTip="Ayarlar">
                        <Path Data="{StaticResource IconSettings}" Style="{StaticResource IconPath}" Width="16" Height="16" Stroke="{StaticResource PrimaryBrush}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Margin="0,4,0,0"
                Background="#FEE2E2"
                BorderBrush="#FECACA"
                BorderThickness="1"
                CornerRadius="8"
                Padding="8,4"
                Visibility="{Binding ShowNoSearchResults, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Sonuç bulunamadı — farklı bir arama deneyin."
                       Foreground="{StaticResource DangerBrush}"
                       FontSize="11" FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>
        </Border>
    </StackPanel>
</UserControl>
