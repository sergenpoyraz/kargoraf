<UserControl x:Class="KargoRaf.Controls.SummaryStripControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource AppFont}">

    <Grid Margin="0,0,0,14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource SummaryStatCard}" Margin="0,0,8,0">
            <StackPanel>
                <TextBlock Text="Toplam aktif" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                <TextBlock Text="{Binding TotalActiveCount}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource SummaryStatCard}" Margin="0,0,8,0">
            <StackPanel>
                <TextBlock Text="En dolu bölüm" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                <TextBlock Text="{Binding BusiestSectionDisplay}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource SummaryStatCard}" Margin="0,0,8,0">
            <StackPanel>
                <TextBlock Text="Bugün eklenen" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                <TextBlock Text="{Binding TodayAddedCount}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="3" Style="{StaticResource SummaryStatCard}">
            <StackPanel>
                <TextBlock Text="Notlu kargo" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                <TextBlock Text="{Binding NotedPackageCount}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource WarningBrush}"/>
            </StackPanel>
        </Border>

        <Border Grid.ColumnSpan="4"
                Margin="0,8,0,-6"
                Background="#FEE2E2"
                BorderBrush="#FECACA"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14,10"
                VerticalAlignment="Bottom"
                Visibility="{Binding ShowNoSearchResults, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Sonuç bulunamadı — farklı bir arama deneyin."
                       Foreground="{StaticResource DangerBrush}"
                       FontSize="13" FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
