<UserControl x:Class="KargoRaf.Controls.SectionCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:KargoRaf.ViewModels"
             xmlns:controls="clr-namespace:KargoRaf.Controls"
             FontFamily="{StaticResource AppFont}">

    <Border Margin="0,0,0,0" VerticalAlignment="Stretch" MinHeight="100"
            Padding="{Binding DataContext.CardPadding, RelativeSource={RelativeSource AncestorType=Window}}">
        <Border.Style>
            <Style TargetType="Border" BasedOn="{StaticResource SectionCardShell}">
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="0"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSearchHighlighted}" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                        <Setter Property="BorderThickness" Value="2"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Width="4" CornerRadius="2" Margin="-10,6,0,6"
                    Background="{Binding AccentBrush}" HorizontalAlignment="Left"/>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Column="0" Grid.RowSpan="2"
                            Width="{Binding DataContext.SectionBadgeSize, RelativeSource={RelativeSource AncestorType=Window}}"
                            Height="{Binding DataContext.SectionBadgeSize, RelativeSource={RelativeSource AncestorType=Window}}"
                            CornerRadius="8"
                            Background="{Binding AccentBrush}"
                            Margin="0,0,8,0"
                            VerticalAlignment="Top">
                        <TextBlock Text="{Binding SortOrder}"
                                   Foreground="White"
                                   FontSize="{Binding DataContext.SectionTitleFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Grid.Column="1" Grid.Row="0"
                               Text="{Binding Name}"
                               TextWrapping="Wrap"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="{Binding DataContext.SectionTitleFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                               Margin="0,0,6,0"/>

                    <Button Grid.Column="2" Grid.Row="0"
                            Style="{StaticResource CompactAddButton}"
                            Width="{Binding DataContext.CompactAddButtonSize, RelativeSource={RelativeSource AncestorType=Window}}"
                            Height="{Binding DataContext.CompactAddButtonSize, RelativeSource={RelativeSource AncestorType=Window}}"
                            MinWidth="{Binding DataContext.CompactAddButtonSize, RelativeSource={RelativeSource AncestorType=Window}}"
                            MinHeight="{Binding DataContext.CompactAddButtonSize, RelativeSource={RelativeSource AncestorType=Window}}"
                            FontSize="18"
                            Content="+"
                            Tag="{Binding SortOrder}"
                            ToolTip="Bu bölüme ekle"
                            VerticalAlignment="Top"
                            Click="SectionQuickAdd_Click"/>

                    <StackPanel Grid.Column="1" Grid.Row="1" Grid.ColumnSpan="2" Margin="0,4,0,0">
                        <Border Visibility="{Binding IsSearchHighlighted, Converter={StaticResource BoolToVis}}"
                                Background="#FFEDD5" CornerRadius="6" Padding="6,2" Margin="0,0,0,4" HorizontalAlignment="Left">
                            <TextBlock Text="eşleşme" Foreground="{StaticResource PrimaryBrush}" FontSize="10" FontWeight="Bold"/>
                        </Border>
                        <Border CornerRadius="8"
                                Background="#EEF2F7"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="8,4"
                                HorizontalAlignment="Left">
                            <TextBlock Text="{Binding Count, StringFormat='{}{0} adet'}"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="{Binding DataContext.SectionCountFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                       FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource PosScrollViewer}"
                                  Visibility="{Binding Count, Converter={StaticResource NullOrEmptyToVis}}">
                        <ItemsControl ItemsSource="{Binding Packages}" AlternationCount="4">
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Margin" Value="0,0,0,6"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:PackageItemViewModel}">
                                    <controls:PackageRowControl/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding Count, Converter={StaticResource NullOrEmptyToVis}, ConverterParameter=Invert}">
                        <Path Data="{StaticResource IconEmptyBox}" Style="{StaticResource IconPath}"
                              Width="24" Height="24" Stroke="{StaticResource MutedTextBrush}" Margin="0,0,0,6"/>
                        <TextBlock Text="Bu bölüm boş"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="{Binding DataContext.EmptyStateFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
