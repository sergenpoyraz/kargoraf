<UserControl x:Class="KargoRaf.Controls.SectionCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:KargoRaf.ViewModels"
             xmlns:controls="clr-namespace:KargoRaf.Controls"
             FontFamily="{StaticResource AppFont}">

    <Border Margin="0,0,12,12" VerticalAlignment="Stretch" MinHeight="150">
        <Border.Style>
            <Style TargetType="Border" BasedOn="{StaticResource SectionCardShell}">
                <Setter Property="BorderThickness" Value="1"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSearchHighlighted}" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                        <Setter Property="BorderThickness" Value="2"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Width="3" CornerRadius="2" Margin="-16,8,0,8"
                    Background="{Binding AccentBrush}" HorizontalAlignment="Left"/>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="10"
                            Background="{Binding AccentBrush}" Margin="0,0,10,0">
                        <TextBlock Text="{Binding SortOrder}"
                                   Foreground="White" FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" Style="{StaticResource SectionTitle}" TextTrimming="CharacterEllipsis"/>
                        <Border Visibility="{Binding IsSearchHighlighted, Converter={StaticResource BoolToVis}}"
                                Background="#DBEAFE" CornerRadius="6" Padding="8,2" Margin="0,4,0,0" HorizontalAlignment="Left">
                            <TextBlock Text="eşleşme" Foreground="{StaticResource PrimaryBrush}" FontSize="10" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>

                    <Border Grid.Column="2" CornerRadius="10"
                            Background="{StaticResource SurfaceMutedBrush}"
                            Padding="10,6" Margin="0,0,8,0" VerticalAlignment="Center">
                        <TextBlock Foreground="{StaticResource BodyTextBrush}" FontSize="13" FontWeight="SemiBold">
                            <Run Text="{Binding Count, Mode=OneWay}"/>
                            <Run Text=" adet" Foreground="{StaticResource MutedTextBrush}"/>
                        </TextBlock>
                    </Border>

                    <Button Grid.Column="3"
                            Style="{StaticResource CompactAddButton}"
                            Content="+"
                            Tag="{Binding SortOrder}"
                            ToolTip="Bu bölüme ekle"
                            Click="SectionQuickAdd_Click"/>
                </Grid>

                <Grid Grid.Row="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource PosScrollViewer}"
                                  Visibility="{Binding Count, Converter={StaticResource NullOrEmptyToVis}}">
                        <ItemsControl ItemsSource="{Binding Packages}" AlternationCount="2">
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Margin" Value="0,0,0,6"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:PackageItemViewModel}">
                                    <controls:PackageRowControl/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding Count, Converter={StaticResource NullOrEmptyToVis}, ConverterParameter=Invert}">
                        <Path Data="{StaticResource IconEmptyBox}" Style="{StaticResource IconPath}"
                              Width="28" Height="28" Stroke="{StaticResource MutedTextBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Bu bölüm boş"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="13" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
