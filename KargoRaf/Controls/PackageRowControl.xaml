<UserControl x:Class="KargoRaf.Controls.PackageRowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource AppFont}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource PackageRowStripe}"/>

        <Border Grid.Column="1"
                Style="{StaticResource PackageRowCard}"
                MouseLeftButtonDown="PackageItem_MouseLeftButtonDown"
                PreviewMouseLeftButtonDown="PackageItem_PreviewMouseLeftButtonDown"
                ToolTip="{Binding NotesTooltip}">
            <StackPanel>
                <TextBlock Text="{Binding RecipientName}"
                           FontSize="{Binding DataContext.PackageNameFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"
                           TextWrapping="Wrap"/>

                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <Border Style="{StaticResource NoteBadge}" Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Visibility="{Binding HasNotes, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconNote}" Style="{StaticResource IconPath}"
                                  Width="11" Height="11" Stroke="{StaticResource WarningBrush}" Margin="0,0,4,0"/>
                            <TextBlock Text="Not var" FontSize="10" FontWeight="Bold" Foreground="#92400E"/>
                        </StackPanel>
                    </Border>
                    <Path Data="{StaticResource IconClock}" Style="{StaticResource IconPath}"
                          Width="12" Height="12" Stroke="{StaticResource MutedTextBrush}" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding CreatedAtDisplay}"
                               FontSize="{Binding DataContext.PackageMetaFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                               Foreground="{StaticResource MutedTextBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Border Style="{StaticResource NotePreviewStrip}"
                        Margin="0,4,0,0"
                        Visibility="{Binding HasNotes, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconNote}" Style="{StaticResource IconPath}"
                              Width="12" Height="12" Stroke="{StaticResource WarningBrush}" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding NotePreviewShort}" Style="{StaticResource NotePreviewText}"/>
                    </StackPanel>
                </Border>

                <Grid HorizontalAlignment="Center"
                      Margin="0,8,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource DeliverButton}"
                            Content="Teslim"
                            Width="{Binding DataContext.DeliverButtonWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                            MinWidth="{Binding DataContext.DeliverButtonWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                            MaxWidth="{Binding DataContext.DeliverButtonWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                            Height="{Binding DataContext.DeliverButtonHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                            MinHeight="{Binding DataContext.DeliverButtonHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                            MaxHeight="{Binding DataContext.DeliverButtonHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                            FontSize="{Binding DataContext.DeliverButtonFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                            Padding="6,0"
                            Command="{Binding DataContext.DeliverCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"
                            Margin="0,0,4,0"/>

                    <Button Grid.Column="1"
                            Style="{StaticResource RowActionIconButton}"
                            ToolTip="Düzenle"
                            Width="{Binding DataContext.RowActionButtonSize, RelativeSource={RelativeSource AncestorType=Window}}"
                            Height="{Binding DataContext.RowActionButtonSize, RelativeSource={RelativeSource AncestorType=Window}}"
                            MinWidth="{Binding DataContext.RowActionButtonSize, RelativeSource={RelativeSource AncestorType=Window}}"
                            MinHeight="{Binding DataContext.RowActionButtonSize, RelativeSource={RelativeSource AncestorType=Window}}"
                            Command="{Binding DataContext.EditPackageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"
                            Margin="0,0,4,0">
                        <Path Data="{StaticResource IconEdit}" Style="{StaticResource IconPath}"
                              Width="15" Height="15" Stroke="{StaticResource MutedTextBrush}"/>
                    </Button>

                    <Button Grid.Column="2"
                            Style="{StaticResource RowActionIconButton}"
                            ToolTip="Notu gör"
                            Width="{Binding DataContext.RowActionButtonSize, RelativeSource={RelativeSource AncestorType=Window}}"
                            Height="{Binding DataContext.RowActionButtonSize, RelativeSource={RelativeSource AncestorType=Window}}"
                            MinWidth="{Binding DataContext.RowActionButtonSize, RelativeSource={RelativeSource AncestorType=Window}}"
                            MinHeight="{Binding DataContext.RowActionButtonSize, RelativeSource={RelativeSource AncestorType=Window}}"
                            Command="{Binding DataContext.ViewNotesCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"
                            Visibility="{Binding HasNotes, Converter={StaticResource BoolToVis}, ConverterParameter=Hidden}">
                        <Path Data="{StaticResource IconNote}" Style="{StaticResource IconPath}"
                              Width="15" Height="15" Stroke="{StaticResource WarningBrush}"/>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
