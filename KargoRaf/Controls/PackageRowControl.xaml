<UserControl x:Class="KargoRaf.Controls.PackageRowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource AppFont}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sol amber accent -->
        <Border Grid.Column="0" Width="4" CornerRadius="2" Margin="0,4,0,4"
                Background="{StaticResource WarningBrush}"
                Visibility="{Binding HasNotes, Converter={StaticResource BoolToVis}}"/>

        <Border Grid.Column="1" CornerRadius="12" Padding="12,10" Cursor="Hand"
                MouseLeftButtonDown="PackageItem_MouseLeftButtonDown"
                PreviewMouseLeftButtonDown="PackageItem_PreviewMouseLeftButtonDown"
                ToolTip="{Binding NotesTooltip}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}}" Value="1">
                            <Setter Property="Background" Value="{StaticResource RowAltBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                            <Setter Property="Background" Value="{StaticResource HighlightRowBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsSearchMatch}" Value="True">
                            <Setter Property="Background" Value="{StaticResource SearchMatchBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter Property="Background" Value="{StaticResource SelectedRowBrush}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            <Setter Property="BorderThickness" Value="2"/>
                        </DataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding HasNotes}" Value="True"/>
                                <Condition Binding="{Binding IsSelected}" Value="False"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Background" Value="{StaticResource NoteSurfaceBrush}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource NoteBorderBrush}"/>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding RecipientName}"
                                   FontSize="17" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"/>
                        <Border Style="{StaticResource NoteBadge}" Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasNotes, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconNote}" Style="{StaticResource IconPath}"
                                      Width="11" Height="11" Stroke="{StaticResource WarningBrush}" Margin="0,0,4,0"/>
                                <TextBlock Text="Not var" FontSize="10" FontWeight="Bold" Foreground="#92400E"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Path Data="{StaticResource IconClock}" Style="{StaticResource IconPath}"
                              Width="12" Height="12" Stroke="{StaticResource MutedTextBrush}" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding CreatedAtDisplay}"
                                   FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                    </StackPanel>

                    <Border Style="{StaticResource NotePreviewStrip}"
                            Visibility="{Binding HasNotes, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconNote}" Style="{StaticResource IconPath}"
                                  Width="12" Height="12" Stroke="{StaticResource WarningBrush}" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding NotePreviewShort}" Style="{StaticResource NotePreviewText}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource DeliverButton}"
                            Content="Teslim"
                            Command="{Binding DataContext.DeliverCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"
                            Margin="0,0,4,0"/>
                    <Button Style="{StaticResource IconButton}"
                            ToolTip="Düzenle"
                            Command="{Binding DataContext.EditPackageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}">
                        <Path Data="{StaticResource IconEdit}" Style="{StaticResource IconPath}"
                              Width="15" Height="15" Stroke="{StaticResource MutedTextBrush}"/>
                    </Button>
                    <Button Style="{StaticResource IconButton}"
                            ToolTip="Notu gör"
                            Command="{Binding DataContext.ViewNotesCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"
                            Visibility="{Binding HasNotes, Converter={StaticResource BoolToVis}}">
                        <Path Data="{StaticResource IconNote}" Style="{StaticResource IconPath}"
                              Width="15" Height="15" Stroke="{StaticResource WarningBrush}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
