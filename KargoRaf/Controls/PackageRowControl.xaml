<UserControl x:Class="KargoRaf.Controls.PackageRowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource AppFont}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource PackageRowStripe}"/>

        <Border Grid.Column="1"
                Style="{StaticResource PackageRowCard}"
                MouseLeftButtonDown="PackageItem_MouseLeftButtonDown"
                PreviewMouseLeftButtonDown="PackageItem_PreviewMouseLeftButtonDown"
                ToolTip="{Binding NotesTooltip}">
            <StackPanel>
                <TextBlock Text="{Binding RecipientName}"
                           FontSize="17" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"
                           TextWrapping="Wrap"/>

                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <Border Style="{StaticResource NoteBadge}" Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Visibility="{Binding HasNotes, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconNote}" Style="{StaticResource IconPath}"
                                  Width="11" Height="11" Stroke="{StaticResource WarningBrush}" Margin="0,0,4,0"/>
                            <TextBlock Text="Not var" FontSize="10" FontWeight="Bold" Foreground="#92400E"/>
                        </StackPanel>
                    </Border>
                    <Path Data="{StaticResource IconClock}" Style="{StaticResource IconPath}"
                          Width="12" Height="12" Stroke="{StaticResource MutedTextBrush}" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding CreatedAtDisplay}"
                               FontSize="12" Foreground="{StaticResource MutedTextBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Border Style="{StaticResource NotePreviewStrip}"
                        Margin="0,4,0,0"
                        Visibility="{Binding HasNotes, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconNote}" Style="{StaticResource IconPath}"
                              Width="12" Height="12" Stroke="{StaticResource WarningBrush}" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding NotePreviewShort}" Style="{StaticResource NotePreviewText}"/>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,10,0,2">
                    <Button Style="{StaticResource DeliverButton}"
                            Content="Teslim"
                            Command="{Binding DataContext.DeliverCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"
                            Margin="0,0,6,0"/>
                    <Button Style="{StaticResource RowActionIconButton}"
                            ToolTip="Düzenle"
                            Command="{Binding DataContext.EditPackageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"
                            Margin="0,0,6,0">
                        <Path Data="{StaticResource IconEdit}" Style="{StaticResource IconPath}"
                              Width="17" Height="17" Stroke="{StaticResource MutedTextBrush}"/>
                    </Button>
                    <Button Style="{StaticResource RowActionIconButton}"
                            ToolTip="Notu gör"
                            Command="{Binding DataContext.ViewNotesCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"
                            Visibility="{Binding HasNotes, Converter={StaticResource BoolToVis}}">
                        <Path Data="{StaticResource IconNote}" Style="{StaticResource IconPath}"
                              Width="17" Height="17" Stroke="{StaticResource WarningBrush}"/>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
