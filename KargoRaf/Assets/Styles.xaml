<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Design tokens - yumuşak ama ayırt edilebilir -->
    <Color x:Key="BgColor">#E8EDF4</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="SurfaceMutedColor">#F1F5F9</Color>
    <Color x:Key="PrimaryColor">#F97316</Color>
    <Color x:Key="PrimaryDarkColor">#EA580C</Color>
    <Color x:Key="SuccessColor">#16A34A</Color>
    <Color x:Key="WarningColor">#D97706</Color>
    <Color x:Key="DangerColor">#DC2626</Color>
    <Color x:Key="TextColor">#0F172A</Color>
    <Color x:Key="BodyTextColor">#1E293B</Color>
    <Color x:Key="MutedTextColor">#64748B</Color>
    <Color x:Key="BorderColor">#CBD5E1</Color>
    <Color x:Key="RowAltColor">#EEF2F7</Color>
    <Color x:Key="RowTone2Color">#FFF4E6</Color>
    <Color x:Key="RowTone3Color">#EFF6FF</Color>
    <Color x:Key="RowStripe0Color">#94A3B8</Color>
    <Color x:Key="RowStripe1Color">#3B82F6</Color>
    <Color x:Key="RowStripe2Color">#F97316</Color>
    <Color x:Key="RowStripe3Color">#8B5CF6</Color>
    <Color x:Key="RowBorderColor">#C5D0DC</Color>
    <Color x:Key="SearchMatchColor">#D1FAE5</Color>
    <Color x:Key="SelectedRowColor">#FFEDD5</Color>
    <Color x:Key="HighlightRowColor">#FEF3C7</Color>
    <Color x:Key="SnackbarBgColor">#0F172A</Color>
    <Color x:Key="NoteSurfaceColor">#FFFBEB</Color>
    <Color x:Key="NoteBorderColor">#FCD34D</Color>
    <Color x:Key="HeroTintColor">#FFF7ED</Color>
    <Color x:Key="SectionShellColor">#FFFFFF</Color>
    <Color x:Key="SectionShellBorderColor">#C5D0DC</Color>

    <sys:Double x:Key="S4" xmlns:sys="clr-namespace:System;assembly=mscorlib">4</sys:Double>
    <sys:Double x:Key="S8" xmlns:sys="clr-namespace:System;assembly=mscorlib">8</sys:Double>
    <sys:Double x:Key="S12" xmlns:sys="clr-namespace:System;assembly=mscorlib">12</sys:Double>
    <sys:Double x:Key="S16" xmlns:sys="clr-namespace:System;assembly=mscorlib">16</sys:Double>
    <sys:Double x:Key="S20" xmlns:sys="clr-namespace:System;assembly=mscorlib">20</sys:Double>
    <sys:Double x:Key="S24" xmlns:sys="clr-namespace:System;assembly=mscorlib">24</sys:Double>
    <CornerRadius x:Key="R10">10</CornerRadius>
    <CornerRadius x:Key="R12">12</CornerRadius>
    <CornerRadius x:Key="R16">16</CornerRadius>
    <CornerRadius x:Key="R20">20</CornerRadius>

    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="NoteSurfaceBrush" Color="{StaticResource NoteSurfaceColor}"/>
    <SolidColorBrush x:Key="NoteBorderBrush" Color="{StaticResource NoteBorderColor}"/>
    <SolidColorBrush x:Key="HeroTintBrush" Color="{StaticResource HeroTintColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceMutedBrush" Color="{StaticResource SurfaceMutedColor}"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="BodyTextBrush" Color="{StaticResource BodyTextColor}"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="RowAltBrush" Color="{StaticResource RowAltColor}"/>
    <SolidColorBrush x:Key="RowTone2Brush" Color="{StaticResource RowTone2Color}"/>
    <SolidColorBrush x:Key="RowTone3Brush" Color="{StaticResource RowTone3Color}"/>
    <SolidColorBrush x:Key="RowStripe0Brush" Color="{StaticResource RowStripe0Color}"/>
    <SolidColorBrush x:Key="RowStripe1Brush" Color="{StaticResource RowStripe1Color}"/>
    <SolidColorBrush x:Key="RowStripe2Brush" Color="{StaticResource RowStripe2Color}"/>
    <SolidColorBrush x:Key="RowStripe3Brush" Color="{StaticResource RowStripe3Color}"/>
    <SolidColorBrush x:Key="RowBorderBrush" Color="{StaticResource RowBorderColor}"/>
    <SolidColorBrush x:Key="SearchMatchBrush" Color="{StaticResource SearchMatchColor}"/>
    <SolidColorBrush x:Key="SelectedRowBrush" Color="{StaticResource SelectedRowColor}"/>
    <SolidColorBrush x:Key="HighlightRowBrush" Color="{StaticResource HighlightRowColor}"/>
    <SolidColorBrush x:Key="SnackbarBgBrush" Color="{StaticResource SnackbarBgColor}"/>
    <SolidColorBrush x:Key="SectionShellBrush" Color="{StaticResource SectionShellColor}"/>
    <SolidColorBrush x:Key="SectionShellBorderBrush" Color="{StaticResource SectionShellBorderColor}"/>

    <FontFamily x:Key="AppFont">Segoe UI Variable Display, Segoe UI</FontFamily>

    <DropShadowEffect x:Key="SoftShadow" BlurRadius="18" ShadowDepth="1" Opacity="0.08" Color="#0F172A"/>
    <DropShadowEffect x:Key="HeroShadow" BlurRadius="24" ShadowDepth="2" Opacity="0.06" Color="#F97316"/>
    <DropShadowEffect x:Key="SnackbarShadow" BlurRadius="20" ShadowDepth="4" Opacity="0.18" Color="#0F172A"/>

    <!-- Cards -->
    <Style x:Key="CardBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBrush}"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="BorderBrush" Value="{StaticResource SectionShellBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Effect" Value="{StaticResource SoftShadow}"/>
    </Style>

    <Style x:Key="HeroPanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource HeroTintBrush}"/>
        <Setter Property="CornerRadius" Value="{StaticResource R20}"/>
        <Setter Property="Padding" Value="24"/>
        <Setter Property="BorderBrush" Value="#FED7AA"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Effect" Value="{StaticResource HeroShadow}"/>
    </Style>

    <Style x:Key="TopBarShell" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="CornerRadius" Value="{StaticResource R16}"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Effect" Value="{StaticResource SoftShadow}"/>
    </Style>

    <Style x:Key="CompactToolbarShell" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderBrush" Value="{StaticResource SectionShellBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Effect" Value="{StaticResource SoftShadow}"/>
    </Style>

    <Style x:Key="SectionCardShell" TargetType="Border" BasedOn="{StaticResource CardBorder}">
        <Setter Property="Background" Value="{StaticResource SectionShellBrush}"/>
        <Setter Property="Padding" Value="14"/>
        <Setter Property="CornerRadius" Value="{StaticResource R16}"/>
    </Style>

    <Style x:Key="NotePreviewStrip" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource NoteSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource NoteBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource R10}"/>
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="Margin" Value="0,6,0,0"/>
    </Style>

    <Style x:Key="NotePreviewText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#92400E"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="PackageRowStripe" TargetType="Border">
        <Setter Property="Width" Value="5"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="Margin" Value="0,6,0,6"/>
        <Setter Property="Background" Value="{StaticResource RowStripe0Brush}"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}}" Value="1">
                <Setter Property="Background" Value="{StaticResource RowStripe1Brush}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}}" Value="2">
                <Setter Property="Background" Value="{StaticResource RowStripe2Brush}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}}" Value="3">
                <Setter Property="Background" Value="{StaticResource RowStripe3Brush}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding HasNotes}" Value="True">
                <Setter Property="Background" Value="{StaticResource WarningBrush}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PackageRowCard" TargetType="Border">
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="12,11"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource RowBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}}" Value="1">
                <Setter Property="Background" Value="{StaticResource RowAltBrush}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}}" Value="2">
                <Setter Property="Background" Value="{StaticResource RowTone2Brush}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}}" Value="3">
                <Setter Property="Background" Value="{StaticResource RowTone3Brush}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                <Setter Property="Background" Value="{StaticResource HighlightRowBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource WarningBrush}"/>
                <Setter Property="BorderThickness" Value="2"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsSearchMatch}" Value="True">
                <Setter Property="Background" Value="{StaticResource SearchMatchBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}"/>
                <Setter Property="BorderThickness" Value="2"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                <Setter Property="Background" Value="{StaticResource SelectedRowBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                <Setter Property="BorderThickness" Value="2"/>
            </DataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding HasNotes}" Value="True"/>
                    <Condition Binding="{Binding IsSelected}" Value="False"/>
                    <Condition Binding="{Binding IsSearchMatch}" Value="False"/>
                    <Condition Binding="{Binding IsHighlighted}" Value="False"/>
                </MultiDataTrigger.Conditions>
                <Setter Property="Background" Value="{StaticResource NoteSurfaceBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource NoteBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
            </MultiDataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="WidgetChip" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource R10}"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Margin" Value="0,0,6,6"/>
    </Style>

    <Style x:Key="WidgetChipActive" TargetType="Border" BasedOn="{StaticResource WidgetChip}">
        <Setter Property="Background" Value="#FFF7ED"/>
        <Setter Property="BorderBrush" Value="#FED7AA"/>
    </Style>

    <Style x:Key="WidgetTickerButton" TargetType="Button">
        <Setter Property="Background" Value="#88FFFFFF"/>
        <Setter Property="BorderBrush" Value="#55E2E8F0"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="Margin" Value="0,0,0,5"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#99FFF7ED"/>
                            <Setter TargetName="bd" Property="BorderBrush" Value="#77FED7AA"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#AAFFEDD5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NoteToggleChip" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource NoteSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource NoteBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="#92400E"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource R10}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#FEF3C7"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ToolbarActionButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource BodyTextBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="MinWidth" Value="64"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource R10}"
                            Padding="{TemplateBinding Padding}">
                        <StackPanel HorizontalAlignment="Center">
                            <ContentPresenter x:Name="icon" HorizontalAlignment="Center"/>
                            <TextBlock Text="{TemplateBinding Tag}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceMutedBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SummaryStatCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="MinWidth" Value="140"/>
    </Style>

    <Style x:Key="SnackbarBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SnackbarBgBrush}"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="Padding" Value="20,14"/>
        <Setter Property="Effect" Value="{StaticResource SnackbarShadow}"/>
        <Setter Property="Opacity" Value="0.96"/>
    </Style>

    <!-- Text inputs -->
    <Style x:Key="HeroTextBox" TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="MinHeight" Value="72"/>
        <Setter Property="Padding" Value="20,14"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="14">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="4,0"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            <Setter TargetName="bd" Property="Background" Value="#FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ModernTextBox" TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="14,11"/>
        <Setter Property="MinHeight" Value="42"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="{StaticResource BodyTextBrush}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Buttons -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Padding" Value="20,12"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HeroAddButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="MinWidth" Value="132"/>
        <Setter Property="MinHeight" Value="72"/>
        <Setter Property="Padding" Value="28,0"/>
    </Style>

    <!-- Quick add bar - sabit yukseklik, celismeyen stiller -->
    <Style x:Key="QuickAddTextBox" TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Height" Value="46"/>
        <Setter Property="MinHeight" Value="46"/>
        <Setter Property="MaxHeight" Value="46"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="2,0"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="QuickAddAddButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Height" Value="46"/>
        <Setter Property="MinHeight" Value="46"/>
        <Setter Property="MaxHeight" Value="46"/>
        <Setter Property="MinWidth" Value="88"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="16,0"/>
    </Style>

    <Style x:Key="QuickAddNoteChip" TargetType="Button" BasedOn="{StaticResource NoteToggleChip}">
        <Setter Property="Height" Value="46"/>
        <Setter Property="MinHeight" Value="46"/>
        <Setter Property="MaxHeight" Value="46"/>
        <Setter Property="MinWidth" Value="58"/>
        <Setter Property="Padding" Value="12,0"/>
    </Style>

    <Style x:Key="CompactAddButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="MinWidth" Value="36"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="FontSize" Value="20"/>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="14,9"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceMutedBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ToolbarButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
        <Setter Property="Padding" Value="14,9"/>
        <Setter Property="MinHeight" Value="40"/>
    </Style>

    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
        <Setter Property="Background" Value="#FEF2F2"/>
        <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
        <Setter Property="BorderBrush" Value="#FECACA"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="10">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceMutedBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ToolbarIconButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
        <Setter Property="Width" Value="30"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceMutedBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FilterChipButton" TargetType="ToggleButton">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource BodyTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="20" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#EFF6FF"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SectionSelectButton" TargetType="ToggleButton">
        <Setter Property="MinWidth" Value="128"/>
        <Setter Property="MinHeight" Value="48"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="14"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#EFF6FF"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DeliverButton" TargetType="Button">
        <Setter Property="MinWidth" Value="120"/>
        <Setter Property="Height" Value="44"/>
        <Setter Property="Background" Value="#DCFCE7"/>
        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
        <Setter Property="BorderBrush" Value="#86EFAC"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Padding" Value="18,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="ToolTip" Value="Teslim edildi"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12"
                            Padding="{TemplateBinding Padding}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="{StaticResource IconCheck}" Style="{StaticResource IconPath}"
                                  Width="16" Height="16" Stroke="{TemplateBinding Foreground}" Margin="0,0,8,0"/>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource SuccessBrush}"/>
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource SuccessBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="RowActionIconButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
        <Setter Property="Width" Value="44"/>
        <Setter Property="Height" Value="44"/>
        <Setter Property="MinWidth" Value="44"/>
        <Setter Property="MinHeight" Value="44"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#E2EAF4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DeliverIconButton" TargetType="Button" BasedOn="{StaticResource DeliverButton}">
        <Setter Property="MinWidth" Value="36"/>
        <Setter Property="Width" Value="36"/>
        <Setter Property="Content" Value=""/>
    </Style>

    <Style x:Key="NoteBadge" TargetType="Border">
        <Setter Property="Background" Value="#FEF3C7"/>
        <Setter Property="BorderBrush" Value="{StaticResource NoteBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource R10}"/>
        <Setter Property="Padding" Value="6,3"/>
    </Style>

    <Style x:Key="PageTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    </Style>

    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="17"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    </Style>

    <Style x:Key="PosScrollViewer" TargetType="ScrollViewer">
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="PanningMode" Value="VerticalOnly"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid>
                        <ScrollContentPresenter/>
                        <ScrollBar x:Name="PART_VerticalScrollBar"
                                   Grid.Column="1" Maximum="{TemplateBinding ScrollableHeight}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Value="{TemplateBinding VerticalOffset}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                   Width="8" HorizontalAlignment="Right" Margin="0,4,2,4">
                            <ScrollBar.Template>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Border Background="Transparent" CornerRadius="4">
                                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                                            <Track.Thumb>
                                                <Thumb>
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Background="#CBD5E1" CornerRadius="4" Margin="1"/>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>
                                        </Track>
                                    </Border>
                                </ControlTemplate>
                            </ScrollBar.Template>
                        </ScrollBar>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ModernComboBox" TargetType="ComboBox">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style x:Key="AppLogoBorder" TargetType="Border">
        <Setter Property="Width" Value="48"/>
        <Setter Property="Height" Value="48"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="BorderBrush" Value="#FED7AA"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FB923C" Offset="0"/>
                    <GradientStop Color="#EA580C" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="LinkButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <ContentPresenter HorizontalAlignment="Left"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource PrimaryDarkBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
