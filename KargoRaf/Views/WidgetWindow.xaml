<Window x:Class="KargoRaf.Views.WidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kargolar"
        Width="220" Height="260"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        FontFamily="{StaticResource AppFont}">

    <Border CornerRadius="18"
            BorderBrush="#55FFFFFF"
            BorderThickness="1"
            Background="#B3FFFFFF"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22" ShadowDepth="3" Opacity="0.2" Color="#0F172A"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="18,18,0,0" Padding="10,8"
                    Background="#CC0891B2">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="pack://application:,,,/Assets/AppIcon.png"
                               Width="20" Height="20" Margin="0,0,8,0"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Foreground="White" FontWeight="Bold" FontSize="13">
                            <Run Text="Kargolar"/>
                            <Run Text=" · " Foreground="#99FFFFFF"/>
                            <Run Text="{Binding TotalCount}" Foreground="#E0F2FE"/>
                        </TextBlock>
                    </StackPanel>
                    <Button Content="✕"
                            HorizontalAlignment="Right"
                            Width="22" Height="22"
                            Padding="0"
                            Background="#33FFFFFF"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="CloseButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="11">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="1" Margin="8,6,8,8"
                    Background="#44F8FAFC"
                    CornerRadius="12"
                    ClipToBounds="True"
                    MinHeight="160">
                <Grid>
                    <TextBlock Text="Aktif kargo yok"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               Visibility="{Binding TotalCount, Converter={StaticResource NullOrEmptyToVis}}"/>

                    <ItemsControl x:Name="TickerPanel"
                                  ItemsSource="{Binding TickerItems}"
                                  Visibility="{Binding TotalCount, Converter={StaticResource NullOrEmptyToVis}, ConverterParameter=Invert}">
                        <ItemsControl.RenderTransform>
                            <TranslateTransform x:Name="TickerTransform"/>
                        </ItemsControl.RenderTransform>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Height" Value="40"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,7" Margin="0,2"
                                        Background="#AAFFFFFF"
                                        CornerRadius="8">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               HorizontalAlignment="Stretch"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
