<Window x:Class="KargoRaf.Views.WidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:KargoRaf.Controls"
        Title="Kargolar"
        Width="286" Height="360"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        FontFamily="{StaticResource AppFont}">

    <Border CornerRadius="22"
            BorderBrush="#66D7E2F1"
            BorderThickness="1"
            Background="#9AFFFFFF"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="34" ShadowDepth="8" Opacity="0.12" Color="#0F172A"/>
        </Border.Effect>

        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="36" Height="36" Style="{StaticResource LogoBadge}" Margin="0,0,10,0">
                        <Path Data="{StaticResource LogoMark}"
                              Style="{StaticResource LogoMarkPath}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Kargolar" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                        <Border Background="#66FFF7ED" BorderBrush="#66FED7AA" BorderThickness="1" CornerRadius="9" Padding="7,2" Margin="0,4,0,0" HorizontalAlignment="Left">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}">
                                <Run Text="Aktif "/>
                                <Run Text="{Binding TotalCount}"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <Button Content="✕"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Width="28" Height="28"
                        Padding="0"
                        Background="#66F1F5F9"
                        Foreground="{StaticResource MutedTextBrush}"
                        BorderBrush="#55E2E8F0"
                        BorderThickness="1"
                        Cursor="Hand"
                        Click="CloseButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="14">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#E2E8F0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <controls:SearchBoxControl Grid.Row="1"
                                       Margin="0,0,0,10"
                                       Height="38"
                                       ShellBackground="#88FFFFFF"
                                       ShellBorderBrush="#55E2E8F0"
                                       SearchText="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                       ClearSearchCommand="{Binding ClearSearchCommand}"/>

            <Border Grid.Row="2"
                    Background="#55F8FAFC"
                    CornerRadius="16"
                    BorderBrush="#55E2E8F0"
                    BorderThickness="1"
                    ClipToBounds="True"
                    MouseEnter="Ticker_MouseEnter"
                    MouseLeave="Ticker_MouseLeave">
                <Grid>
                    <TextBlock Text="Aktif kargo yok"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"/>

                    <Grid x:Name="TickerViewport"
                          Margin="8"
                          ClipToBounds="True"
                          Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                        <StackPanel x:Name="TickerStack">
                            <StackPanel.RenderTransform>
                                <TranslateTransform x:Name="TickerTransform" Y="0"/>
                            </StackPanel.RenderTransform>

                            <ItemsControl x:Name="TickerPrimary" ItemsSource="{Binding TickerItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource WidgetTickerButton}"
                                                Command="{Binding DataContext.OpenPackageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding NotePreview}"
                                                               FontSize="10.5"
                                                               FontWeight="SemiBold"
                                                               Foreground="#B45309"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,2,0,0"
                                                               Visibility="{Binding HasNotes, Converter={StaticResource BoolToVis}}"/>
                                                </StackPanel>
                                                <Border Grid.Column="1"
                                                        Width="22" Height="22"
                                                        CornerRadius="11"
                                                        Background="{StaticResource NoteSurfaceBrush}"
                                                        BorderBrush="{StaticResource NoteBorderBrush}"
                                                        BorderThickness="1"
                                                        Margin="8,0,0,0"
                                                        Visibility="{Binding HasNotes, Converter={StaticResource BoolToVis}}">
                                                    <Path Data="{StaticResource IconNote}"
                                                          Style="{StaticResource IconPath}"
                                                          Width="12" Height="12"
                                                          Stroke="{StaticResource WarningBrush}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
