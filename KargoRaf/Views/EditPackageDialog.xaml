<Window x:Class="KargoRaf.Views.EditPackageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kargo Düzenle"
        Width="500" Height="540"
        MinWidth="460" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontFamily="{StaticResource AppFont}"
        Background="{StaticResource BgBrush}">

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Image Source="pack://application:,,,/Assets/AppIcon.png"
                   Width="44" Height="44" Stretch="Uniform" Margin="0,0,14,0"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Kargo Düzenle" Style="{StaticResource PageTitle}" FontSize="22"/>
                <TextBlock x:Name="StatusText"
                           Text="Değişiklikler otomatik kaydedilir"
                           Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,4,0,0"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Alıcı adı" Foreground="{StaticResource MutedTextBrush}"
                           FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox x:Name="NameBox" Style="{StaticResource ModernTextBox}"
                         FontSize="16" MinHeight="50" MaxLength="120"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Bölüm" Foreground="{StaticResource MutedTextBrush}"
                           FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <ComboBox x:Name="SectionBox"
                          Style="{StaticResource ModernComboBox}"
                          MinHeight="50"
                          VerticalContentAlignment="Center">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontSize="15" Padding="4,2">
                                <Run Text="Bölüm "/>
                                <Run Text="{Binding SortOrder}" FontWeight="Bold"/>
                                <Run Text=" · "/>
                                <Run Text="{Binding Name}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,12">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconNote}" Style="{StaticResource IconPath}"
                              Width="14" Height="14" Stroke="{StaticResource WarningBrush}" Margin="0,0,6,0"/>
                        <TextBlock Text="Not (opsiyonel)" Foreground="#92400E"
                                   FontSize="12" FontWeight="SemiBold"/>
                    </StackPanel>
                    <TextBlock x:Name="NotesCounter" HorizontalAlignment="Right"
                               Foreground="{StaticResource MutedTextBrush}" FontSize="11"/>
                </Grid>
                <TextBox x:Name="NotesBox" Style="{StaticResource ModernTextBox}"
                         MaxLength="500" MinHeight="100"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top" Padding="14,12"
                         BorderBrush="{StaticResource NoteBorderBrush}"
                         Background="{StaticResource NoteSurfaceBrush}"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="İptal" Style="{StaticResource SecondaryButton}"
                    MinWidth="100" MinHeight="44" Margin="0,0,10,0"
                    Click="Cancel_Click"/>
            <Button Content="Kaydet" Style="{StaticResource PrimaryButton}"
                    MinWidth="100" MinHeight="44"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
