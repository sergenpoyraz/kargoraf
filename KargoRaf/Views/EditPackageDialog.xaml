<Window x:Class="KargoRaf.Views.EditPackageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kargo Düzenle"
        Width="500" Height="560"
        MinWidth="460" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontFamily="{StaticResource AppFont}"
        Background="{StaticResource BgBrush}">

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Başlık + logo -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,22">
            <Border Style="{StaticResource AppLogoBorder}" Width="48" Height="48" CornerRadius="14" Margin="0,0,14,0">
                <Image Source="pack://application:,,,/Assets/AppIcon.png"
                       Width="32" Height="32"
                       Stretch="Uniform"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Kargo Düzenle" Style="{StaticResource PageTitle}" FontSize="22"/>
                <TextBlock Text="Alıcı, bölüm ve notu güncelle"
                           Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,4,0,0"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Alıcı adı" Foreground="{StaticResource MutedTextBrush}"
                           FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox x:Name="NameBox" Style="{StaticResource ModernTextBox}"
                         FontSize="16" MinHeight="50" MaxLength="120"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Bölüm" Foreground="{StaticResource MutedTextBrush}"
                           FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <ComboBox x:Name="SectionBox"
                          Style="{StaticResource ModernComboBox}"
                          MinHeight="50"
                          VerticalContentAlignment="Center">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontSize="15" Padding="4,2">
                                <Run Text="Bölüm "/>
                                <Run Text="{Binding SortOrder}" FontWeight="Bold"/>
                                <Run Text=" · "/>
                                <Run Text="{Binding Name}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Not (opsiyonel)" Foreground="{StaticResource MutedTextBrush}"
                           FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox x:Name="NotesBox" Style="{StaticResource ModernTextBox}"
                         MaxLength="500" MinHeight="96"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top" Padding="14,12"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="İptal" Style="{StaticResource SecondaryButton}"
                    MinWidth="108" MinHeight="44" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Kaydet" Style="{StaticResource PrimaryButton}"
                    MinWidth="108" MinHeight="44" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
