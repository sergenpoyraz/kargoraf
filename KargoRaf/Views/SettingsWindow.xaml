<Window x:Class="KargoRaf.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ayarlar — Kargo Raf"
        Width="720" Height="820"
        MinWidth="580" MinHeight="640"
        Background="{StaticResource BgBrush}"
        FontFamily="{StaticResource AppFont}"
        WindowStartupLocation="CenterOwner">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,20,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Baslik -->
            <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,18">
                <StackPanel Orientation="Horizontal">
                    <Image Source="pack://application:,,,/Assets/AppIcon.png"
                           Width="40" Height="40"
                           Stretch="Uniform"
                           Margin="0,0,14,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Ayarlar" Style="{StaticResource SettingsSectionTitle}" FontSize="22"/>
                        <TextBlock Text="Bölümler, görünüm, yedekleme ve veri yönetimi."
                                   Style="{StaticResource SettingsSectionSubtitle}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Bolumler -->
            <StackPanel Grid.Row="1" Margin="0,0,0,18">
                <TextBlock Text="Bölüm Ayarları" Style="{StaticResource SettingsSectionTitle}"/>
                <TextBlock Text="Bölüm adlarını düzenleyin; boş bölümleri pasif yapabilirsiniz."
                           Style="{StaticResource SettingsSectionSubtitle}"/>
                <Border Style="{StaticResource CardBorder}" Padding="16">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding Sections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource SurfaceMutedBrush}"
                                            CornerRadius="12" Padding="12" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="88"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="{Binding Label}" FontWeight="Bold"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextBrush}"/>
                                            <TextBlock Grid.Row="1" Text="{Binding PackageInfo}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       Margin="0,4,0,0"/>

                                            <TextBox Grid.Column="1" Grid.RowSpan="2"
                                                     Style="{StaticResource ModernTextBox}"
                                                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                     MaxLength="100"
                                                     Margin="8,0,8,0"
                                                     VerticalAlignment="Center"/>

                                            <Button Grid.Column="2" Grid.RowSpan="2"
                                                    Content="Pasif Yap"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Padding="10,8"
                                                    Foreground="{StaticResource DangerBrush}"
                                                    IsEnabled="{Binding CanRemove}"
                                                    Command="{Binding DataContext.RemoveSectionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Sadece boş bölümler pasif yapılabilir"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Content="+ Yeni Bölüm Ekle"
                                Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Stretch"
                                Margin="0,4,0,0"
                                Command="{Binding AddSectionCommand}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Gorunum -->
            <StackPanel Grid.Row="2" Margin="0,0,0,18">
                <TextBlock Text="Görünüm" Style="{StaticResource SettingsSectionTitle}"/>
                <TextBlock Text="Ekran yoğunluğu ve bölüm kartı kaydırma davranışı."
                           Style="{StaticResource SettingsSectionSubtitle}"/>
                <Border Style="{StaticResource CardBorder}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Bölüm kartları yoğunluğu" Style="{StaticResource SettingsFieldLabel}"/>
                        <ComboBox ItemsSource="{Binding DensityItems}"
                                  SelectedItem="{Binding SelectedDensityItem}"
                                  DisplayMemberPath="Title"
                                  Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding SelectedDensityHint}"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="12"/>

                        <CheckBox Content="Bölüm kartları otomatik kaydırma animasyonu"
                                  IsChecked="{Binding SectionAutoScrollEnabled}"
                                  Margin="0,14,0,0"
                                  FontSize="13"/>
                        <TextBlock Text="Kapalıyken kartlar sabit kalır; fare tekerleği ve sürükleyerek kaydırabilirsiniz."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="11"
                                   Margin="24,4,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Yedek & Veriler -->
            <StackPanel Grid.Row="3" Margin="0,0,0,18">
                <TextBlock Text="Yedek &amp; Veriler" Style="{StaticResource SettingsSectionTitle}"/>
                <TextBlock Text="Tüm kargo kayıtları bilgisayarınızda saklanır. Yedekler otomatik olarak aşağıdaki klasöre kaydedilir."
                           Style="{StaticResource SettingsSectionSubtitle}"/>

                <Border Style="{StaticResource CardBorder}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Canlı veritabanı" Style="{StaticResource SettingsFieldLabel}"/>
                        <Border Style="{StaticResource SettingsPathBox}">
                            <TextBlock Text="{Binding DatabasePath}"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       Foreground="{StaticResource BodyTextBrush}"/>
                        </Border>

                        <TextBlock Text="Yedek klasörü" Style="{StaticResource SettingsFieldLabel}" Margin="0,4,0,4"/>
                        <TextBlock Text="«Veritabanı Yedeği Al» dediğinizde kargoraf_TARIH.backup.db dosyası bu klasöre kopyalanır."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="11"
                                   Margin="0,0,0,6"/>
                        <Border Style="{StaticResource SettingsPathBox}"
                                Background="#F0FDF4"
                                BorderBrush="#BBF7D0">
                            <TextBlock Text="{Binding BackupsFolderPath}"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"/>
                        </Border>
                        <TextBlock Text="{Binding BackupInfoSummary}"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="11"
                                   Margin="0,0,0,12"/>

                        <UniformGrid Columns="2" Margin="0,0,0,8">
                            <Button Content="Veritabanı Yedeği Al"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,6,0"
                                    Command="{Binding BackupCommand}"/>
                            <Button Content="Yedek Klasörünü Aç"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="6,0,0,0"
                                    Command="{Binding OpenBackupsFolderCommand}"/>
                        </UniformGrid>

                        <TextBlock Text="Excel / tablo olarak dışa aktarma"
                                   Style="{StaticResource SettingsFieldLabel}"
                                   Margin="0,8,0,4"/>
                        <UniformGrid Columns="2">
                            <Button Content="Aktif Kargolar CSV"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,6,0"
                                    Command="{Binding ExportActiveCommand}"/>
                            <Button Content="Geçmiş CSV"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="6,0,0,0"
                                    Command="{Binding ExportHistoryCommand}"/>
                        </UniformGrid>
                        <TextBlock Text="CSV dosyası kaydederken konumu siz seçersiniz."
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="11"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Tehlikeli -->
            <StackPanel Grid.Row="4" Margin="0,0,0,18">
                <TextBlock Text="Tehlikeli İşlemler" Style="{StaticResource SettingsSectionTitle}"/>
                <TextBlock Text="Geri alınamaz işlemler — önce yedek almanız önerilir."
                           Style="{StaticResource SettingsSectionSubtitle}"/>
                <Border Style="{StaticResource CardBorder}" Padding="16"
                        BorderBrush="#FECACA"
                        Background="#FFFFFBFB">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="Tüm kargo verilerini sil"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource DangerBrush}"/>
                            <TextBlock Text="Aktif ve geçmişteki tüm kargo kayıtlarını kalıcı olarak siler. Bölüm adları ve uygulama ayarları korunur."
                                       FontSize="12"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,5,0,0"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="Tüm Kargoları Sil"
                                Style="{StaticResource DangerButton}"
                                Padding="14,9"
                                VerticalAlignment="Center"
                                Command="{Binding DeleteAllPackagesCommand}"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Kisayollar -->
            <StackPanel Grid.Row="5" Margin="0,0,0,18">
                <TextBlock Text="Klavye Kısayolları" Style="{StaticResource SettingsSectionTitle}"/>
                <Border Style="{StaticResource CardBorder}" Padding="16">
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource BodyTextBrush}" FontSize="13" LineHeight="24">
                        Ctrl+1..9 — Seçili bölüme hızlı ekle&#x0a;
                        Enter — Kargo ekle&#x0a;
                        Ctrl+F — Ara&#x0a;
                        Esc — Aramayı temizle&#x0a;
                        Ctrl+W — Mini widget&#x0a;
                        Delete — Seçili kargoyu teslim et
                    </TextBlock>
                </Border>
            </StackPanel>

            <!-- Hakkında -->
            <Border Grid.Row="6" Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal">
                    <Image Source="pack://application:,,,/Assets/AppIcon.png"
                           Width="36" Height="36"
                           Stretch="Uniform"
                           Margin="0,0,14,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Kargo Raf" FontSize="17" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="Bölümlere göre kargo takibi — v2.0.0"
                                   Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Kaydet -->
            <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                <TextBlock Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"
                           Foreground="{StaticResource SuccessBrush}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           MaxWidth="380"/>
                <Button Content="Kaydet" Style="{StaticResource PrimaryButton}" MinWidth="100" Command="{Binding SaveCommand}"/>
            </StackPanel>

            <!-- Gelistirici -->
            <Border Grid.Row="8" Margin="0,20,0,0" Padding="0,16,0,0"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Geliştirici: Sergen Poyraz"
                               FontSize="12"
                               Foreground="{StaticResource MutedTextBrush}"
                               HorizontalAlignment="Center"/>
                    <Button Content="WhatsApp ile iletişim (+90 506 058 80 60)"
                            Style="{StaticResource LinkButton}"
                            HorizontalAlignment="Center"
                            Margin="0,6,0,0"
                            Click="OpenWhatsApp_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
