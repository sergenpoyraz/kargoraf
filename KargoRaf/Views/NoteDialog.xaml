<Window x:Class="KargoRaf.Views.NoteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Not"
        Width="440" Height="300"
        MinWidth="360" MinHeight="240"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource BgBrush}"
        FontFamily="{StaticResource AppFont}">
    <Border Margin="18" Style="{StaticResource CardBorder}" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                <Border Width="34" Height="34" CornerRadius="12"
                        Background="{StaticResource NoteSurfaceBrush}"
                        BorderBrush="{StaticResource NoteBorderBrush}"
                        BorderThickness="1"
                        Margin="0,0,10,0">
                    <Path Data="{StaticResource IconNote}"
                          Style="{StaticResource IconPath}"
                          Width="17" Height="17"
                          Stroke="{StaticResource WarningBrush}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="Kargo notu" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}"/>
                </StackPanel>
            </StackPanel>

            <Border Grid.Row="1"
                    Background="{StaticResource SurfaceMutedBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource PosScrollViewer}">
                    <TextBlock x:Name="NoteText"
                               FontSize="14"
                               Foreground="{StaticResource BodyTextBrush}"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>

            <Button Grid.Row="2"
                    Content="Kapat"
                    Style="{StaticResource PrimaryButton}"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0"
                    Padding="18,9"
                    Click="Close_Click"/>
        </Grid>
    </Border>
</Window>
