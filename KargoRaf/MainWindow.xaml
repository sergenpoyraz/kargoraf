<Window x:Class="KargoRaf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:KargoRaf.ViewModels"
        Title="Kargo Raf"
        Width="1360" Height="880"
        MinWidth="1024" MinHeight="700"
        FontFamily="{StaticResource AppFont}"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="MainWindow_PreviewKeyDown">

    <Window.InputBindings>
        <KeyBinding Key="W" Modifiers="Control" Command="{Binding ToggleWidgetCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeliverSelectedCommand}"/>
    </Window.InputBindings>

    <Grid>
        <!-- Arka plan gradient -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#EEF2FF" Offset="0"/>
                <GradientStop Color="#F8FAFC" Offset="0.45"/>
                <GradientStop Color="#F1F5F9" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Margin="22,18,22,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Üst bar -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Style="{StaticResource AppLogoBorder}" Margin="0,0,14,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.15" Color="#2563EB"/>
                        </Border.Effect>
                        <Image Source="pack://application:,,,/Assets/AppIcon.png"
                               Width="34" Height="34"
                               Stretch="Uniform"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Kargo Raf" FontSize="26" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="Hızlı kargo kayıt" Foreground="{StaticResource MutedTextBrush}" FontSize="13" Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="White" CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="2">
                        <TextBox x:Name="SearchBox"
                                 Width="210"
                                 Style="{StaticResource ModernTextBox}"
                                 BorderThickness="0"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    </Border>
                    <Button Content="Widget" Style="{StaticResource ToolbarButton}" Margin="10,0,0,0"
                            Command="{Binding ToggleWidgetCommand}" ToolTip="Ctrl+W"/>
                    <Button Content="Geçmiş" Style="{StaticResource ToolbarButton}" Margin="6,0,0,0"
                            Command="{Binding OpenHistoryCommand}"/>
                    <Button Content="Ayarlar" Style="{StaticResource ToolbarButton}" Margin="6,0,0,0"
                            Command="{Binding OpenSettingsCommand}"/>
                </StackPanel>
            </Grid>

            <!-- Hero panel -->
            <Border Grid.Row="1" CornerRadius="22" Margin="0,0,0,18" BorderBrush="#BFDBFE" BorderThickness="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#F8FAFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="32" ShadowDepth="4" Opacity="0.10" Color="#2563EB"/>
                </Border.Effect>

                <Grid Margin="26,22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Background="{StaticResource PrimaryBrush}" CornerRadius="8" Padding="10,4" Margin="0,0,10,0">
                                <TextBlock Text="{Binding SelectedSectionDisplay}"
                                           Foreground="White" FontSize="13" FontWeight="Bold"/>
                            </Border>
                            <TextBlock Text="{Binding KeyboardHint}"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="12"/>
                        </StackPanel>

                        <TextBox x:Name="QuickAddBox"
                                 Grid.Row="1"
                                 Style="{StaticResource HeroTextBox}"
                                 Text="{Binding QuickAddName, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewKeyDown="QuickAddBox_PreviewKeyDown"/>

                        <TextBlock Grid.Row="2"
                                   Text="{Binding QuickAddHelperText}"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="12"
                                   Margin="6,10,0,0"/>

                        <TextBlock Grid.Row="3"
                                   Text="{Binding WarningMessage}"
                                   Foreground="{StaticResource WarningBrush}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Margin="6,8,0,0"
                                   Visibility="{Binding WarningMessage, Converter={StaticResource NullOrEmptyToVis}, ConverterParameter=Invert}"/>
                    </Grid>

                    <!-- Aktif sayaç -->
                    <Border Grid.Column="1"
                            MinWidth="130"
                            Margin="24,0"
                            CornerRadius="20"
                            VerticalAlignment="Center"
                            Padding="22,18">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#2563EB" Offset="0"/>
                                <GradientStop Color="#1D4ED8" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding TotalActiveCount}"
                                       FontSize="52" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       LineHeight="52"/>
                            <TextBlock Text="aktif kargo"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="#BFDBFE"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Button Grid.Column="2"
                            Style="{StaticResource HeroAddButton}"
                            VerticalAlignment="Center"
                            Command="{Binding AddCommand}">
                        <StackPanel>
                            <TextBlock Text="EKLE" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="↵ Enter" FontSize="11" Opacity="0.85" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- Bölüm kartları — ekrana sığacak şekilde esnek grid -->
            <ItemsControl Grid.Row="2"
                          VerticalAlignment="Stretch"
                          ItemsSource="{Binding Sections}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="{Binding DataContext.SectionGridColumns, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:SectionCardViewModel}">
                        <Border Margin="0,0,12,12"
                                Style="{StaticResource CardBorder}"
                                VerticalAlignment="Stretch"
                                MinHeight="140">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Height="5" CornerRadius="5" Margin="-20,-20,-20,14"
                                            Background="{Binding AccentBrush}"/>

                                    <Grid Grid.Row="0" Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="14"
                                                Background="{Binding AccentBrush}" Margin="0,0,12,0">
                                            <TextBlock Text="{Binding SortOrder}"
                                                       Foreground="White" FontSize="20" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource SectionTitle}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Border Visibility="{Binding IsSearchHighlighted, Converter={StaticResource BoolToVis}}"
                                                    Background="#DBEAFE" CornerRadius="6" Padding="8,2" Margin="0,4,0,0" HorizontalAlignment="Left">
                                                <TextBlock Text="eşleşme" Foreground="{StaticResource PrimaryBrush}" FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>

                                        <Border Grid.Column="2" CornerRadius="14"
                                                Background="{StaticResource SurfaceMutedBrush}"
                                                Padding="14,8" Margin="0,0,10,0" VerticalAlignment="Center">
                                            <TextBlock FontSize="26" FontWeight="Bold" Foreground="{StaticResource TextBrush}">
                                                <Run Text="{Binding Count, Mode=OneWay}"/>
                                            </TextBlock>
                                        </Border>

                                        <Button Grid.Column="3"
                                                Content="+"
                                                Width="44" Height="44"
                                                Style="{StaticResource PrimaryButton}"
                                                Padding="0" FontSize="22"
                                                Tag="{Binding SortOrder}"
                                                ToolTip="Bu bölüme ekle"
                                                Click="SectionQuickAdd_Click"/>
                                    </Grid>

                                    <Border Grid.Row="1"
                                            Background="{StaticResource SurfaceMutedBrush}"
                                            CornerRadius="12"
                                            Padding="16,18"
                                            Margin="0,0,0,8"
                                            Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="Bu bölüm boş"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="15"
                                                   HorizontalAlignment="Center"/>
                                    </Border>

                                    <ScrollViewer Grid.Row="2"
                                                  VerticalScrollBarVisibility="Auto"
                                                  Style="{StaticResource PosScrollViewer}">
                                        <ItemsControl ItemsSource="{Binding Packages}" AlternationCount="2">
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Margin" Value="0,0,0,3"/>
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:PackageItemViewModel}">
                                                    <Border CornerRadius="12" Padding="12,10" Cursor="Hand"
                                                            MouseLeftButtonDown="PackageItem_MouseLeftButtonDown"
                                                            PreviewMouseLeftButtonDown="PackageItem_PreviewMouseLeftButtonDown">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}}" Value="1">
                                                                        <Setter Property="Background" Value="{StaticResource RowAltBrush}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                                        <Setter Property="Background" Value="#FEF3C7"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsSearchMatch}" Value="True">
                                                                        <Setter Property="Background" Value="#D1FAE5"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="Background" Value="#DBEAFE"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding RecipientName}"
                                                                           FontSize="17" FontWeight="SemiBold"
                                                                           Foreground="{StaticResource TextBrush}"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding Notes}"
                                                                           FontSize="12"
                                                                           Foreground="{StaticResource MutedTextBrush}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Margin="0,2,0,0"
                                                                           Visibility="{Binding Notes, Converter={StaticResource NullOrEmptyToVis}, ConverterParameter=Invert}"/>
                                                            </StackPanel>
                                                            <Button Grid.Column="1"
                                                                    Style="{StaticResource DeliverIconButton}"
                                                                    Command="{Binding DataContext.DeliverCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    VerticalAlignment="Center"
                                                                    Margin="8,0,0,0"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Alt bildirimler -->
            <Grid Grid.Row="3" Margin="0,10,0,0">
                <Border Background="#0F172A" CornerRadius="14" Padding="18,12"
                        HorizontalAlignment="Center"
                        Visibility="{Binding ShowStatusToast, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                </Border>

                <Border Background="#0F172A" CornerRadius="14" Padding="18,12"
                        HorizontalAlignment="Center"
                        Visibility="{Binding ShowUndoBar, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center">
                            <Run Text="{Binding UndoMessage}"/>
                        </TextBlock>
                        <Button Content="Geri Al" Margin="18,0,0,0"
                                Style="{StaticResource PrimaryButton}"
                                Background="{StaticResource SuccessBrush}"
                                Padding="16,8"
                                Command="{Binding UndoCommand}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
