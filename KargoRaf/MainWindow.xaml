<Window x:Class="KargoRaf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:KargoRaf.ViewModels"
        xmlns:controls="clr-namespace:KargoRaf.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Kargo Raf"
        Width="1024" Height="680"
        MinWidth="800" MinHeight="580"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource BgBrush}"
        FontFamily="{StaticResource AppFont}"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="MainWindow_PreviewKeyDown">

    <shell:WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="8"
                      UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <DataTemplate x:Key="SectionCardWideTemplate" DataType="{x:Type vm:SectionCardViewModel}">
            <controls:SectionCardControl
                Width="{Binding DataContext.CardWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                Margin="{Binding DataContext.CardMargin, RelativeSource={RelativeSource AncestorType=Window}}"/>
        </DataTemplate>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="W" Modifiers="Control" Command="{Binding ToggleWidgetCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeliverSelectedCommand}"/>
    </Window.InputBindings>

    <Grid x:Name="RootGrid" Margin="12,10,12,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <controls:TopBarControl x:Name="TopBar" Grid.Row="0" Margin="0,0,0,6"/>

        <controls:QuickAddPanel x:Name="QuickAdd" Grid.Row="1" Margin="0,0,0,2" VerticalAlignment="Top"/>

        <ScrollViewer x:Name="HorizontalSectionsScroll"
                      Grid.Row="2"
                      VerticalScrollBarVisibility="Disabled"
                      HorizontalScrollBarVisibility="Hidden"
                      PanningMode="HorizontalOnly"
                      MouseEnter="HorizontalSectionsScroll_MouseEnter"
                      MouseLeave="HorizontalSectionsScroll_MouseLeave"
                      PreviewMouseLeftButtonDown="HorizontalSectionsScroll_PreviewMouseLeftButtonDown"
                      PreviewMouseMove="HorizontalSectionsScroll_PreviewMouseMove"
                      PreviewMouseLeftButtonUp="HorizontalSectionsScroll_PreviewMouseLeftButtonUp"
                      PreviewMouseWheel="HorizontalSectionsScroll_PreviewMouseWheel">
            <ItemsControl ItemsSource="{Binding Sections}"
                          ItemTemplate="{StaticResource SectionCardWideTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <controls:SnackbarControl Grid.Row="3" Margin="0,6,0,0"/>
    </Grid>
</Window>
